# ── Application ─────────────────────────────────────────────────────────────
APP_NAME="Shared AI Interface Backend"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://saib:changeme@localhost:5432/saib
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SESSION=7200
REDIS_TTL_PROMPT_CACHE=3600
REDIS_TTL_MODEL_RESPONSE=300

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-secure-random-string-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# ── OpenAI (optional — used as fallback) ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# ── Azure Storage (for document uploads) ─────────────────────────────────────
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_BLOB_CONTAINER=documents

# ── Celery ───────────────────────────────────────────────────────────────────
# Leave empty to use REDIS_URL automatically
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Safety ───────────────────────────────────────────────────────────────────
INJECTION_DETECTION_ENABLED=true
OUTPUT_MODERATION_ENABLED=true

# ── Context Limits ───────────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=8192
MAX_SESSION_MESSAGES=20
MAX_RAG_CHUNKS=5
